---
import type { CollectionEntry } from 'astro:content'
import { Image } from 'astro:assets'

import FormattedDate from '../components/FormattedDate.astro'
import BaseHead from '../components/BaseHead.astro'
import Header from '../components/Header.astro'

type Props = CollectionEntry<'recipes'>['data']
const { title, prepTime, cookTime, inactiveTime, pubDate, heroImage, ingredients, serves } = Astro.props
---

<head>
  <BaseHead title={title} />
  <script>
    import { IngredientScaler } from '../components/ingredient-scaler.ts'
    customElements.define('ingredient-scaler', IngredientScaler)
  </script>
</head>
<main class="recipe-page">
  <Header />

  <div class="recipe-page-shell">
    <a
      href="/recipes"
      class="recipe-back-link"
    >
      &larr; Recipes
    </a>

    <article class="recipe-sheet">
      <ingredient-scaler
        class="block"
        data-ingredients={JSON.stringify(ingredients)}
        data-serves={serves}
      >
        <div class="recipe-sheet-photo">
          {
            heroImage && (
              <Image
                src={heroImage}
                alt={title}
                widths={[480, 768, 1024, 1536]}
                sizes="(min-width: 1040px) 1040px, 100vw"
                priority
              />
            )
          }
        </div>

        <div class="recipe-sheet-body">
          <p class="recipe-date"><FormattedDate date={pubDate} /></p>
          <h1 class="recipe-title">{title}</h1>

          <div class="recipe-badges">
            <span class="badge badge-clay">Prep {prepTime}</span>
            <span class="badge badge-herb">Cook {cookTime}</span>
            {inactiveTime && <span class="badge badge-muted">+ {inactiveTime}</span>}
          </div>

          <div class="serves-control">
            <label
              for="multiplier-input"
              class="serves-label"
            >
              Serves
            </label>
            <div class="stepper">
              <button
                type="button"
                class="stepper-btn"
                data-step="-1"
                aria-label="Decrease servings"
              >
                &minus;
              </button>
              <input
                class="stepper-input"
                type="number"
                id="multiplier-input"
                value={serves}
                step="1"
              />
              <button
                type="button"
                class="stepper-btn"
                data-step="1"
                aria-label="Increase servings"
              >
                +
              </button>
            </div>
          </div>

          <div class="recipe-body-grid">
            <section class="ingredients-col">
              <h3 class="section-heading">Ingredients</h3>
              <div
                id="ingredient-root"
                class="ingredient-list-wrap"
              >
              </div>
            </section>

            <section class="instructions-col">
              <div class="instructions-header">
                <h3 class="section-heading">Instructions</h3>
                <button
                  type="button"
                  id="zen-toggle"
                  class="zen-toggle-btn"
                >
                  Zen Mode
                </button>
              </div>

              <div
                id="zen-nav"
                class="zen-nav"
                hidden
              >
                <button
                  type="button"
                  id="zen-prev"
                  class="zen-nav-btn"
                  aria-label="Previous step"
                >
                  &larr;
                </button>
                <span
                  id="zen-progress"
                  class="zen-progress"
                ></span>
                <button
                  type="button"
                  id="zen-next"
                  class="zen-nav-btn"
                  aria-label="Next step"
                >
                  &rarr;
                </button>
              </div>

              <div
                id="instructions-container"
                class="instructions-wrap"
              >
                <slot />
              </div>
            </section>
          </div>
        </div>
      </ingredient-scaler>
    </article>
  </div>

  <footer class="recipe-footer">
    <p><a href="/recipes">&larr; Back to Recipes</a></p>
  </footer>
</main>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target
    if (!(target instanceof Element)) return
    const btn = target.closest('[data-step]')
    if (!btn) return
    const input = document.getElementById('multiplier-input')
    if (!(input instanceof HTMLInputElement)) return
    const step = Number(btn.getAttribute('data-step')) || 0
    const current = parseFloat(input.value) || 0
    const next = Math.max(1, current + step)
    input.value = String(next)
    input.dispatchEvent(new Event('input', { bubbles: true }))
  })
</script>

<style>
  .recipe-page {
    display: block;
    background: var(--paper);
    color: var(--cocoa);
    min-height: 100vh;
  }

  .recipe-page-shell {
    max-width: 1120px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .recipe-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--forest-soft);
    text-decoration: none;
    margin-bottom: 1.25rem;
    transition: color 0.15s ease;
  }
  .recipe-back-link:hover {
    color: var(--clay);
  }

  .recipe-sheet {
    background: var(--paper-card);
    border: 1px solid var(--paper-line);
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 30px 70px -35px var(--paper-shadow);
  }

  .recipe-sheet-photo {
    width: 100%;
    aspect-ratio: 16 / 8;
    overflow: hidden;
    background: var(--paper-line);
  }
  .recipe-sheet-photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recipe-sheet-body {
    padding: 2rem 1.5rem 2.75rem;
  }
  @media (min-width: 640px) {
    .recipe-sheet-body {
      padding: 2.5rem 3rem 3.5rem;
    }
  }

  .recipe-date {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cocoa-faint);
    margin-bottom: 0.6rem;
  }
  .recipe-title {
    font-family: var(--serif);
    font-weight: 700;
    font-size: clamp(2rem, 4vw, 2.85rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--forest);
    margin-bottom: 1.1rem;
  }

  .recipe-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.04em;
  }
  .badge-clay {
    background: var(--clay-dim);
    color: var(--clay);
  }
  .badge-herb {
    background: var(--herb-dim);
    color: var(--herb);
  }
  .badge-muted {
    background: var(--paper);
    border: 1px solid var(--paper-line);
    color: var(--cocoa-soft);
  }

  .serves-control {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 1.75rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid var(--paper-line);
  }
  .serves-label {
    font-family: var(--mono);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--cocoa-soft);
  }
  .stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--paper-line);
    border-radius: 999px;
    background: var(--paper);
    overflow: hidden;
  }
  .stepper-btn {
    width: 2.1rem;
    height: 2.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--forest);
    background: transparent;
    transition: background 0.15s ease;
  }
  .stepper-btn:hover {
    background: var(--herb-dim);
  }
  .stepper-input {
    width: 3rem;
    text-align: center;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--sans);
    font-weight: 600;
    font-size: 1rem;
    color: var(--cocoa);
    -moz-appearance: textfield;
  }
  .stepper-input::-webkit-outer-spin-button,
  .stepper-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .recipe-body-grid {
    display: grid;
    gap: 2.5rem;
  }
  @media (min-width: 860px) {
    .recipe-body-grid {
      grid-template-columns: 300px 1fr;
      align-items: start;
    }
    .ingredients-col {
      position: sticky;
      top: 1.5rem;
    }
  }

  .section-heading {
    font-family: var(--serif);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--forest);
    padding-bottom: 0.65rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--paper-line);
  }

  /* Ingredients (rendered by ingredient-scaler.ts) */
  .ingredient-list-wrap :global(h5) {
    font-family: var(--mono);
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clay);
    margin: 1.5rem 0 0.65rem;
  }
  .ingredient-list-wrap :global(h5:first-child) {
    margin-top: 0;
  }
  .ingredient-list-wrap :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .ingredient-list-wrap :global(li) {
    position: relative;
    padding-left: 1.35rem;
    font-size: 0.98rem;
    line-height: 1.5;
    color: var(--cocoa);
  }
  .ingredient-list-wrap :global(li::before) {
    content: '';
    position: absolute;
    left: 1px;
    top: 0.55em;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--herb);
    transform: rotate(45deg);
  }

  /* Instructions (rendered markdown) */
  .instructions-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    font-size: 1.02rem;
    line-height: 1.75;
    color: var(--cocoa);
  }

  /* Each numbered step is a self-contained container so zen mode can show
     exactly one at a time; freeform content (bullet lists, raw HTML, etc.)
     inside a step is left untouched. Numbering comes from a data attribute
     (set in ingredient-scaler.ts) rather than a CSS counter, since counters
     don't increment across steps hidden by zen mode's display: none. */
  .instructions-wrap :global(.step) {
    position: relative;
    padding-left: 3.1rem;
    min-height: 2.3rem;
  }
  .instructions-wrap :global(.step > *) {
    margin: 0;
  }
  .instructions-wrap :global(.step > * + *) {
    margin-top: 0.75rem;
  }
  .instructions-wrap :global(.step::before) {
    content: attr(data-step-number);
    position: absolute;
    left: 0;
    top: 0;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    background: var(--clay);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--mono);
    font-size: 0.85rem;
    font-weight: 600;
  }
  .instructions-wrap :global(.step ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .instructions-wrap :global(.step ul li) {
    position: relative;
    padding-left: 1.35rem;
  }
  .instructions-wrap :global(.step ul li::before) {
    content: '';
    position: absolute;
    left: 1px;
    top: 0.55em;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--herb);
    transform: rotate(45deg);
  }

  /* Zen mode: show one step at a time */
  .instructions-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.65rem;
    margin-bottom: 1rem;
    border-bottom: 2px solid var(--paper-line);
  }
  .instructions-header .section-heading {
    padding-bottom: 0;
    margin-bottom: 0;
    border-bottom: none;
  }
  .zen-toggle-btn {
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--forest-soft);
    background: var(--paper);
    border: 1px solid var(--paper-line);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    transition:
      background 0.15s ease,
      color 0.15s ease;
  }
  .zen-toggle-btn:hover {
    background: var(--herb-dim);
    color: var(--forest);
  }
  .zen-toggle-btn.is-active {
    background: var(--herb);
    border-color: var(--herb);
    color: #fff;
  }
  .zen-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }
  .zen-nav-btn {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 50%;
    border: 1px solid var(--paper-line);
    background: var(--paper);
    color: var(--forest);
    font-size: 1.1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s ease;
  }
  .zen-nav-btn:hover:not(:disabled) {
    background: var(--herb-dim);
  }
  .zen-nav-btn:disabled {
    opacity: 0.35;
    cursor: default;
  }
  .zen-progress {
    font-family: var(--mono);
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cocoa-soft);
    min-width: 7rem;
    text-align: center;
  }
  .instructions-wrap.zen-active :global(.step) {
    display: none;
  }
  .instructions-wrap.zen-active :global(.step.zen-current) {
    display: block;
    padding-left: 3.6rem;
    font-size: 1.12rem;
    line-height: 1.85;
  }
  .instructions-wrap.zen-active :global(.step.zen-current::before) {
    width: 2.6rem;
    height: 2.6rem;
    font-size: 1rem;
  }
  .instructions-wrap :global(a) {
    color: var(--clay);
    text-underline-offset: 2px;
  }
  .instructions-wrap :global(a:hover) {
    color: var(--forest);
    text-decoration: underline;
  }
  .instructions-wrap :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 14px;
    border: 1px solid var(--paper-line);
    margin: 1.25rem 0;
  }
  .instructions-wrap :global(code) {
    border-radius: 5px;
    background: var(--paper);
    border: 1px solid var(--paper-line);
    padding: 0.1rem 0.4rem;
    font-family: var(--mono);
    font-size: 0.9em;
  }
  .instructions-wrap :global(pre) {
    margin: 1.5rem 0;
    overflow-x: auto;
    border-radius: 14px;
    border: 1px solid var(--paper-line);
    background: var(--paper);
    padding: 1.25rem;
  }
  .instructions-wrap :global(pre code) {
    background: transparent;
    border: none;
    padding: 0;
  }
  .instructions-wrap :global(blockquote) {
    margin: 1.5rem 0;
    border-left: 3px solid var(--clay);
    padding-left: 1.1rem;
    font-size: 1.05rem;
    font-style: italic;
    color: var(--cocoa-soft);
  }
  .instructions-wrap :global(hr) {
    margin: 1.5rem 0;
    border: none;
    border-top: 1px solid var(--paper-line);
  }

  .recipe-footer {
    border-top: 1px solid var(--paper-line);
    padding: 2rem 1.5rem 3rem;
    text-align: center;
    font-family: var(--mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--cocoa-faint);
  }
  .recipe-footer a {
    color: var(--forest-soft);
    text-decoration: none;
  }
  .recipe-footer a:hover {
    color: var(--clay);
  }
</style>
