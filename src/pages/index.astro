---
import { Image } from 'astro:assets'
import recipesPreview from '../content/recipes/parmesan-egg-in-the-hole.png'
import spellsPreview from '../assets/spells-card.png'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />
    <title>Byte Garden</title>
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-[#0b1410]">
    <header
      class="hero"
      data-screen-label="01 Hero"
    >
      <div class="grid"></div>

      <div
        class="vines"
        aria-hidden="true"
      >
        <svg
          viewBox="0 0 1440 900"
          preserveAspectRatio="xMidYMid slice"
        >
          <defs>
            <linearGradient
              id="vgrad"
              x1="0"
              y1="0"
              x2="0"
              y2="1"
            >
              <stop
                offset="0%"
                stop-color="#7ce39a"
                stop-opacity="0.75"
              ></stop>
              <stop
                offset="100%"
                stop-color="#2e6a4a"
                stop-opacity="0.15"
              ></stop>
            </linearGradient>
            <linearGradient
              id="vgrad-soft"
              x1="0"
              y1="0"
              x2="1"
              y2="0"
            >
              <stop
                offset="0%"
                stop-color="#4fa872"
                stop-opacity="0.55"
              ></stop>
              <stop
                offset="100%"
                stop-color="#4fa872"
                stop-opacity="0.05"
              ></stop>
            </linearGradient>
            <filter id="glow">
              <feGaussianBlur
                stdDeviation="2"
                result="b"
              ></feGaussianBlur>
              <feMerge><feMergeNode in="b"></feMergeNode><feMergeNode in="SourceGraphic"></feMergeNode></feMerge>
            </filter>
          </defs>

          <g
            filter="url(#glow)"
            stroke-width="1.25"
          >
            <path
              id="vL-main"
              class="vine-path"
              stroke="url(#vgrad)"
              d="M 80 900 L 80 720 L 180 720 L 180 580 L 260 580 L 260 460 L 340 460 L 340 320 L 460 320"
            ></path>
            <path
              id="vL-b1"
              class="vine-path delay-1"
              stroke="url(#vgrad-soft)"
              d="M 80 720 L 20 720 L 20 640"
            ></path>
            <path
              id="vL-b2"
              class="vine-path delay-1"
              stroke="url(#vgrad-soft)"
              d="M 180 580 L 240 580 L 240 540 L 300 540"
            ></path>
            <path
              id="vL-b3"
              class="vine-path delay-2"
              stroke="url(#vgrad-soft)"
              d="M 260 460 L 200 460 L 200 400 L 140 400"
            ></path>
            <path
              id="vL-b4"
              class="vine-path delay-2"
              stroke="url(#vgrad-soft)"
              d="M 340 320 L 340 240 L 420 240 L 420 180"
            ></path>
            <path
              id="vL-b5"
              class="vine-path delay-3"
              stroke="url(#vgrad-soft)"
              d="M 460 320 L 540 320 L 540 260"
            ></path>
          </g>

          <g
            filter="url(#glow)"
            stroke-width="1.25"
          >
            <path
              id="vR-main"
              class="vine-path delay-1"
              stroke="url(#vgrad)"
              d="M 1360 0 L 1360 140 L 1260 140 L 1260 240 L 1180 240 L 1180 340 L 1100 340 L 1100 460 L 1000 460 L 1000 560"
            ></path>
            <path
              id="vR-b1"
              class="vine-path delay-2"
              stroke="url(#vgrad-soft)"
              d="M 1260 240 L 1320 240 L 1320 300"
            ></path>
            <path
              id="vR-b2"
              class="vine-path delay-3"
              stroke="url(#vgrad-soft)"
              d="M 1180 340 L 1240 340 L 1240 400 L 1300 400"
            ></path>
            <path
              id="vR-b3"
              class="vine-path delay-3"
              stroke="url(#vgrad-soft)"
              d="M 1100 460 L 1100 540 L 1180 540"
            ></path>
            <path
              id="vR-b4"
              class="vine-path delay-4"
              stroke="url(#vgrad-soft)"
              d="M 1000 560 L 940 560 L 940 620"
            ></path>
          </g>

          <g
            filter="url(#glow)"
            stroke-width="1.25"
          >
            <path
              id="vBR-main"
              class="vine-path delay-4"
              stroke="url(#vgrad)"
              d="M 1440 820 L 1300 820 L 1300 760 L 1200 760 L 1200 700"
            ></path>
            <path
              id="vBR-b1"
              class="vine-path delay-5"
              stroke="url(#vgrad-soft)"
              d="M 1300 820 L 1300 880"
            ></path>
          </g>

          <g
            filter="url(#glow)"
            stroke-width="1.25"
          >
            <path
              id="vBL-main"
              class="vine-path delay-3"
              stroke="url(#vgrad)"
              d="M 600 900 L 600 840 L 680 840 L 680 800 L 760 800"
            ></path>
            <path
              id="vBL-b1"
              class="vine-path delay-4"
              stroke="url(#vgrad-soft)"
              d="M 680 840 L 680 880"
            ></path>
          </g>

          <g aria-hidden="true">
            <use
              href="#vL-main"
              class="packet-trail d1"
            ></use>
            <use
              href="#vL-main"
              class="packet-trail slow d3 ember"
            ></use>
            <use
              href="#vL-b2"
              class="packet-trail fast d2"
            ></use>
            <use
              href="#vL-b4"
              class="packet-trail d4"
            ></use>
            <use
              href="#vR-main"
              class="packet-trail d2"
            ></use>
            <use
              href="#vR-main"
              class="packet-trail slow d5 ember"
            ></use>
            <use
              href="#vR-b2"
              class="packet-trail fast d1"
            ></use>
            <use
              href="#vR-b3"
              class="packet-trail d3"
            ></use>
            <use
              href="#vBR-main"
              class="packet-trail d5"
            ></use>
            <use
              href="#vBL-main"
              class="packet-trail fast d4"
            ></use>
          </g>

          <g>
            <circle
              class="vine-node"
              cx="80"
              cy="720"
              r="3.5"
              style="animation-delay:1.8s, 3.0s"
            ></circle>
            <circle
              class="vine-node slow"
              cx="180"
              cy="580"
              r="3.5"
              style="animation-delay:2.0s, 3.4s"
            ></circle>
            <circle
              class="vine-node fast"
              cx="260"
              cy="460"
              r="3.5"
              style="animation-delay:2.2s, 3.2s"
            ></circle>
            <circle
              class="vine-node ember"
              cx="340"
              cy="320"
              r="4.5"
              style="animation-delay:2.4s, 3.1s"
            ></circle>
            <circle
              class="vine-node"
              cx="460"
              cy="320"
              r="3.5"
              style="animation-delay:2.6s, 3.6s"
            ></circle>
            <circle
              class="vine-node slow"
              cx="420"
              cy="180"
              r="3.5"
              style="animation-delay:2.8s, 3.5s"
            ></circle>

            <circle
              class="vine-node fast"
              cx="1260"
              cy="240"
              r="3.5"
              style="animation-delay:2.2s, 3.3s"
            ></circle>
            <circle
              class="vine-node ember"
              cx="1180"
              cy="340"
              r="4.5"
              style="animation-delay:2.4s, 3.0s"
            ></circle>
            <circle
              class="vine-node"
              cx="1100"
              cy="460"
              r="3.5"
              style="animation-delay:2.6s, 3.7s"
            ></circle>
            <circle
              class="vine-node slow"
              cx="1000"
              cy="560"
              r="3.5"
              style="animation-delay:2.8s, 3.4s"
            ></circle>
            <circle
              class="vine-node"
              cx="1320"
              cy="300"
              r="3.5"
              style="animation-delay:3.0s, 3.8s"
            ></circle>

            <circle
              class="vine-node fast"
              cx="600"
              cy="840"
              r="3.5"
              style="animation-delay:3.0s, 3.5s"
            ></circle>
            <circle
              class="vine-node"
              cx="1300"
              cy="760"
              r="3.5"
              style="animation-delay:3.2s, 3.9s"
            ></circle>

            <rect
              class="vine-blossom"
              x="-5"
              y="-5"
              width="10"
              height="10"
              transform="translate(20 640)"
              style="animation-delay:2.4s, 3.0s; fill: #7ce39a"
            ></rect>
            <rect
              class="vine-blossom"
              x="-5"
              y="-5"
              width="10"
              height="10"
              transform="translate(140 400)"
              style="animation-delay:2.6s, 3.2s; fill: #7ce39a"
            ></rect>
            <rect
              class="vine-blossom"
              x="-5"
              y="-5"
              width="10"
              height="10"
              transform="translate(300 540)"
              style="animation-delay:2.8s, 3.4s; fill: #7ce39a"
            ></rect>
            <rect
              class="vine-blossom"
              x="-6"
              y="-6"
              width="12"
              height="12"
              transform="translate(940 620)"
              style="animation-delay:3.0s, 3.6s; fill: #e8a06b"
            ></rect>
            <rect
              class="vine-blossom"
              x="-5"
              y="-5"
              width="10"
              height="10"
              transform="translate(1180 540)"
              style="animation-delay:3.0s, 3.1s; fill: #7ce39a"
            ></rect>
            <rect
              class="vine-blossom"
              x="-5"
              y="-5"
              width="10"
              height="10"
              transform="translate(1200 700)"
              style="animation-delay:3.2s, 3.8s; fill: #7ce39a"
            ></rect>
          </g>
        </svg>
      </div>

      <nav class="nav">
        <div class="lhs">
          <span class="dot"></span>
          <span>byte-garden / v1.0</span>
        </div>
        <div class="rhs">
          <a href="#projects">~/projects</a>
          <a href="/recipes">~/recipes</a>
        </div>
      </nav>

      <div class="hero-content">
        <div class="hero-pill">A GROWING COLLECTION OF PROJECTS</div>
        <h1 class="wordmark">
          Byte<svg
            class="sprout"
            viewBox="0 0 20 26"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            ><path d="M 10 26 L 10 10"></path><path d="M 10 18 L 4 18 L 4 13"></path><path d="M 10 14 L 16 14 L 16 8"></path><circle
              cx="4"
              cy="13"
              r="1.6"
              fill="currentColor"
              stroke="none"
            ></circle><circle
              cx="16"
              cy="8"
              r="1.6"
              fill="currentColor"
              stroke="none"
            ></circle><circle
              cx="10"
              cy="6"
              r="2"
              fill="currentColor"
              stroke="none"
            ></circle></svg
          ><span class="amp">Garden</span><span class="cursor"></span>
        </h1>
        <p class="tagline">Tools, writing, and whatever else I feel like putting here.</p>
        <p class="submeta">
          <span>est. 2025</span>
          <span class="sep">·</span>
          <a
            href="https://github.com/daniel-slaugh"
            target="_blank"
            rel="noopener noreferrer"
            ><svg
              viewBox="0 0 16 16"
              width="11"
              height="11"
              fill="currentColor"
              aria-hidden="true"
              style="vertical-align:-1px;margin-right:0.35em;opacity:0.85"
              ><path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              ></path></svg
            >@daniel-slaugh</a
          >
        </p>
      </div>

      <div class="scroll-cue">
        <span>cd projects</span>
        <span class="line"></span>
      </div>
    </header>

    <section
      class="section"
      id="projects"
      data-screen-label="02 Projects"
    >
      <div class="section-head">
        <h2 class="section-title"><span class="prompt">$ ls</span>projects/</h2>
        <span class="section-meta">3 directories</span>
      </div>

      <div class="cards">
        <a
          class="card"
          href="/recipes"
        >
          <div class="card-window">
            <div class="lights"><span></span><span></span><span></span></div>
            <span class="path">~/recipes</span>
          </div>
          <div class="card-preview-wrap">
            <div class="card-preview">
              <Image
                src={recipesPreview}
                alt=""
                widths={[320, 640]}
                sizes="(min-width: 760px) 320px, 100vw"
              />
            </div>
          </div>
          <div class="card-body">
            <div class="card-head">
              <h3 class="card-title">Recipes</h3>
              <span class="card-arrow">→</span>
            </div>
            <p class="card-desc">A collection of recipes I'm always iterating on.</p>
            <div class="card-foot">
              <span class="tag">#cooking #cozy</span>
              <span class="status">live</span>
            </div>
          </div>
        </a>

        <a
          class="card"
          href="/spells"
        >
          <div class="card-window">
            <div class="lights"><span></span><span></span><span></span></div>
            <span class="path">~/spells</span>
          </div>
          <div class="card-preview-wrap parchment">
            <div class="card-preview contain">
              <Image
                src={spellsPreview}
                alt="An Accio spell card on parchment"
                widths={[320, 640]}
                sizes="(min-width: 760px) 320px, 100vw"
              />
            </div>
          </div>
          <div class="card-body">
            <div class="card-head">
              <h3 class="card-title">Spellbook</h3>
              <span class="card-arrow">→</span>
            </div>
            <p class="card-desc">Guess what? I'm a DM now! Thanks to @Murphen44 writing a tremendous amount of resources, I'm running a Founder's era Hogwarts campaign. This is a filterable webpage of his spells PDF.</p>
            <div class="card-foot">
              <span class="tag">#dnd #reference</span>
              <span class="status">live</span>
            </div>
          </div>
        </a>

        <div class="card seed-card">
          <div class="card-window">
            <div class="lights"><span></span><span></span><span></span></div>
            <span class="path">~/blog</span>
          </div>
          <div class="card-preview-wrap seed-preview">
            <span class="glyph">{'{   }'}</span>
          </div>
          <div class="card-body">
            <div class="card-head">
              <h3 class="card-title">Dev blog, eventually</h3>
              <span class="card-arrow">+</span>
            </div>
            <p class="card-desc">I have a lot to say about data management and engineering. If only I could find the time to write about it.</p>
            <div class="card-foot">
              <span class="tag">#writing</span>
              <span class="status seed">germinating</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <footer>
      <div></div>
      <div>
        <a
          href="https://github.com/daniel-slaugh"
          target="_blank"
          rel="noopener noreferrer"
          >github</a
        >
        &nbsp;·&nbsp;
        <a
          href="https://orcid.org/0009-0005-7886-0822"
          target="_blank"
          rel="noopener noreferrer"
          >orcid</a
        >
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #0b1410;
        --bg-mid: #0f1a14;
        --bg-card: #121d17;
        --bg-raised: #16241c;
        --border: #1f3328;
        --border-hot: #2a4a37;

        --green: #7ce39a;
        --green-soft: #4fa872;
        --green-deep: #2e6a4a;
        --green-glow: rgba(124, 227, 154, 0.15);

        --ember: #e8a06b;
        --ember-dim: rgba(232, 160, 107, 0.1);

        --ink: #e8e0d0;
        --ink-soft: #98a89e;
        --ink-faint: #5a6e62;
        --ink-ghost: #38483e;

        --serif: 'Lora', Georgia, serif;
        --sans: 'DM Sans', system-ui, sans-serif;
        --mono: 'DM Mono', ui-monospace, monospace;
      }

      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      html {
        scroll-behavior: smooth;
        color-scheme: dark;
      }

      body {
        font-family: var(--sans);
        background: var(--bg);
        color: var(--ink);
        min-height: 100vh;
        overflow-x: hidden;
        position: relative;
        line-height: 1.55;
      }

      body::before {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background: radial-gradient(ellipse 60% 50% at 15% 0%, rgba(124, 227, 154, 0.1) 0%, transparent 60%), radial-gradient(ellipse 70% 55% at 90% 105%, rgba(232, 160, 107, 0.08) 0%, transparent 55%), radial-gradient(ellipse 40% 50% at 100% 20%, rgba(46, 106, 74, 0.1) 0%, transparent 60%);
      }
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        opacity: 0.035;
        mix-blend-mode: overlay;
        background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='180' height='180'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/></filter><rect width='100%25' height='100%25' filter='url(%23n)'/></svg>");
      }

      .hero {
        position: relative;
        min-height: 100vh;
        padding: 2.5rem 3rem 4rem;
        display: grid;
        grid-template-rows: auto 1fr auto;
        isolation: isolate;
        overflow: hidden;
      }

      .vines {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      .vines svg {
        width: 100%;
        height: 100%;
        display: block;
      }

      .grid {
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image: linear-gradient(to right, rgba(46, 106, 74, 0.1) 1px, transparent 1px), linear-gradient(to bottom, rgba(46, 106, 74, 0.1) 1px, transparent 1px);
        background-size: 56px 56px;
        background-position: -1px -1px;
        mask-image: radial-gradient(ellipse 80% 70% at 50% 40%, #000 30%, transparent 90%);
      }

      .nav {
        position: relative;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        color: var(--ink-soft);
      }
      .nav .lhs {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }
      .nav .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 10px var(--green);
        animation: pulse 2.4s ease-in-out infinite;
      }
      @keyframes pulse {
        0%,
        100% {
          opacity: 1;
          box-shadow: 0 0 10px var(--green);
        }
        50% {
          opacity: 0.55;
          box-shadow: 0 0 4px var(--green);
        }
      }
      .nav .rhs {
        display: flex;
        gap: 1.5rem;
      }
      .nav a {
        color: var(--ink-soft);
        text-decoration: none;
        transition: color 0.15s;
      }
      .nav a:hover {
        color: var(--green);
      }

      .hero-content {
        position: relative;
        z-index: 4;
        align-self: center;
        max-width: 880px;
        margin: 4rem auto 2rem;
        text-align: center;
      }

      .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        font-family: var(--mono);
        font-size: 0.66rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--green-soft);
        padding: 0.45rem 0.9rem;
        border: 1px solid var(--border-hot);
        border-radius: 999px;
        background: rgba(124, 227, 154, 0.04);
        margin-bottom: 2.25rem;
      }
      .hero-pill::before {
        content: '';
        width: 5px;
        height: 5px;
        background: var(--green);
        border-radius: 50%;
        box-shadow: 0 0 8px var(--green);
      }

      .wordmark {
        font-family: var(--serif);
        font-size: clamp(3.5rem, 10vw, 7.5rem);
        font-weight: 700;
        line-height: 0.95;
        letter-spacing: -0.035em;
        color: var(--ink);
        margin-bottom: 1.5rem;
      }
      .wordmark .amp {
        font-weight: 700;
        color: var(--ink);
      }
      .wordmark .sprout {
        display: inline-block;
        width: 0.7em;
        height: 0.9em;
        margin: 0 0.15em -0.05em;
        vertical-align: baseline;
        color: var(--green);
        filter: drop-shadow(0 0 8px var(--green-glow));
      }
      .wordmark .cursor {
        display: inline-block;
        width: 0.06em;
        height: 0.85em;
        margin-left: 0.08em;
        background: var(--green);
        vertical-align: -0.08em;
        box-shadow: 0 0 12px var(--green-glow);
        animation: blink 1.05s steps(2, end) infinite;
      }
      @keyframes blink {
        50% {
          opacity: 0;
        }
      }

      .tagline {
        font-family: var(--serif);
        font-style: italic;
        font-weight: 400;
        font-size: clamp(1rem, 1.6vw, 1.25rem);
        color: var(--ink-soft);
        max-width: 560px;
        margin: 0 auto 0.4rem;
        line-height: 1.5;
      }
      .submeta {
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.06em;
        color: var(--ink-faint);
      }
      .submeta .sep {
        color: var(--ink-ghost);
        margin: 0 0.5rem;
      }
      .submeta a {
        color: var(--ink-faint);
        text-decoration: none;
        transition: color 0.15s;
      }
      .submeta a:hover {
        color: var(--green);
      }

      .scroll-cue {
        position: relative;
        z-index: 4;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.6rem;
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-faint);
        padding-bottom: 0.5rem;
      }
      .scroll-cue .line {
        width: 1px;
        height: 38px;
        background: linear-gradient(to bottom, transparent, var(--green-deep) 30%, var(--green) 100%);
        animation: trickle 2.2s ease-in-out infinite;
        transform-origin: top;
      }
      @keyframes trickle {
        0%,
        100% {
          opacity: 0.4;
          transform: scaleY(0.7);
        }
        50% {
          opacity: 1;
          transform: scaleY(1);
        }
      }

      .section {
        position: relative;
        z-index: 2;
        padding: 5rem 3rem 6rem;
        max-width: 1280px;
        margin: 0 auto;
      }

      .section-head {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 1.25rem;
      }
      .section-title {
        font-family: var(--serif);
        font-size: 1.65rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--ink);
      }
      .section-title .prompt {
        font-family: var(--mono);
        font-weight: 400;
        font-size: 0.95rem;
        color: var(--green);
        margin-right: 0.5rem;
      }
      .section-meta {
        font-family: var(--mono);
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        color: var(--ink-faint);
        text-transform: uppercase;
      }

      .cards {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.25rem;
      }

      .card {
        position: relative;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 10px;
        overflow: hidden;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        transition:
          transform 0.25s ease,
          border-color 0.25s ease,
          box-shadow 0.25s ease;
      }
      .card:hover {
        transform: translateY(-3px);
        border-color: var(--border-hot);
        box-shadow:
          0 12px 32px -16px rgba(0, 0, 0, 0.6),
          0 0 0 1px rgba(124, 227, 154, 0.08),
          0 0 28px -8px var(--green-glow);
      }
      .card:hover .card-arrow {
        color: var(--green);
        transform: translateX(3px);
      }
      .card:hover .card-preview {
        transform: scale(1.04);
      }

      .card-window {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.85rem;
        background: var(--bg-mid);
        border-bottom: 1px solid var(--border);
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.06em;
        color: var(--ink-faint);
      }
      .card-window .lights {
        display: flex;
        gap: 0.3rem;
      }
      .card-window .lights span {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--ink-ghost);
      }
      .card-window .lights span:first-child {
        background: #4a3a32;
      }
      .card-window .lights span:nth-child(2) {
        background: #4a4632;
      }
      .card-window .lights span:nth-child(3) {
        background: var(--green-deep);
      }
      .card-window .path {
        margin-left: 0.4rem;
        color: var(--ink-soft);
      }

      .card-preview-wrap {
        position: relative;
        aspect-ratio: 16 / 9;
        overflow: hidden;
        background: var(--bg-raised);
        border-bottom: 1px solid var(--border);
      }
      .card-preview {
        position: absolute;
        inset: 0;
        transition: transform 0.5s ease;
      }
      .card-preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        filter: saturate(0.85) brightness(0.85);
      }
      .card-preview-svg {
        width: 100%;
        height: 100%;
      }
      .card-preview-wrap.parchment {
        background: radial-gradient(ellipse 80% 70% at 50% 35%, #f0e7d2 0%, #d8cdb1 80%, #c2b694 100%);
      }
      .card-preview.contain img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        filter: none;
      }

      .card-body {
        padding: 1.1rem 1.1rem 1.2rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        flex: 1;
      }
      .card-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.8rem;
      }
      .card-title {
        font-family: var(--serif);
        font-size: 1.2rem;
        font-weight: 600;
        letter-spacing: -0.015em;
        color: var(--ink);
        line-height: 1.2;
      }
      .card-arrow {
        font-family: var(--mono);
        font-size: 0.95rem;
        color: var(--ink-faint);
        transition:
          transform 0.2s ease,
          color 0.2s ease;
        flex-shrink: 0;
        line-height: 1.2;
      }
      .card-desc {
        font-size: 0.85rem;
        color: var(--ink-soft);
        line-height: 1.55;
        font-weight: 300;
      }
      .card-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.6rem;
        margin-top: 0.4rem;
        padding-top: 0.7rem;
        border-top: 1px dashed var(--border);
        font-family: var(--mono);
        font-size: 0.62rem;
        letter-spacing: 0.08em;
        color: var(--ink-faint);
        text-transform: uppercase;
      }
      .tag {
        color: var(--green-soft);
      }
      .status {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
      }
      .status::before {
        content: '';
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 6px var(--green-glow);
      }
      .status.wip::before {
        background: var(--ember);
        box-shadow: 0 0 6px rgba(232, 160, 107, 0.5);
      }
      .status.seed::before {
        background: var(--ink-ghost);
        box-shadow: none;
      }
      .status.wip {
        color: var(--ember);
      }
      .status.seed {
        color: var(--ink-faint);
      }

      .card.seed-card {
        background: transparent;
        border-style: dashed;
      }
      .card.seed-card:hover {
        transform: translateY(-3px);
        border-style: dashed;
        border-color: var(--border-hot);
      }
      .seed-preview {
        aspect-ratio: 16 / 9;
        display: grid;
        place-items: center;
        background: repeating-linear-gradient(45deg, transparent 0 12px, rgba(124, 227, 154, 0.04) 12px 13px);
      }
      .seed-preview .glyph {
        font-family: var(--mono);
        font-size: 2.2rem;
        color: var(--green-deep);
        letter-spacing: 0.1em;
      }

      footer {
        position: relative;
        z-index: 2;
        padding: 2.5rem 3rem 3rem;
        font-family: var(--mono);
        font-size: 0.68rem;
        letter-spacing: 0.06em;
        color: var(--ink-faint);
        display: flex;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }
      footer a {
        color: var(--ink-soft);
        text-decoration: none;
      }
      footer a:hover {
        color: var(--green);
      }

      .vine-path {
        fill: none;
        stroke-linecap: round;
        stroke-linejoin: round;
        stroke-dasharray: 1200;
        stroke-dashoffset: 1200;
        animation: draw 5s ease-out forwards;
      }
      .vine-path.delay-1 {
        animation-delay: 0.2s;
      }
      .vine-path.delay-2 {
        animation-delay: 0.6s;
      }
      .vine-path.delay-3 {
        animation-delay: 1s;
      }
      .vine-path.delay-4 {
        animation-delay: 1.4s;
      }
      .vine-path.delay-5 {
        animation-delay: 1.8s;
      }
      @keyframes draw {
        to {
          stroke-dashoffset: 0;
        }
      }

      .vine-node {
        fill: var(--green);
        opacity: 0;
        transform-box: fill-box;
        transform-origin: center;
        animation:
          bloom 0.6s ease-out forwards,
          nodePulse 2.8s ease-in-out infinite 3s;
      }
      .vine-node.ember {
        fill: var(--ember);
        animation:
          bloom 0.6s ease-out forwards,
          emberPulse 3.6s ease-in-out infinite 3s;
      }
      .vine-node.fast {
        animation:
          bloom 0.6s ease-out forwards,
          nodePulse 1.6s ease-in-out infinite 3s;
      }
      .vine-node.slow {
        animation:
          bloom 0.6s ease-out forwards,
          nodePulse 4.2s ease-in-out infinite 3s;
      }
      @keyframes bloom {
        to {
          opacity: 1;
        }
      }
      @keyframes nodePulse {
        0%,
        100% {
          opacity: 0.55;
          filter: drop-shadow(0 0 1px rgba(124, 227, 154, 0.4));
          transform: scale(0.85);
        }
        50% {
          opacity: 1;
          filter: drop-shadow(0 0 6px rgba(124, 227, 154, 0.9));
          transform: scale(1.25);
        }
      }
      @keyframes emberPulse {
        0%,
        100% {
          opacity: 0.6;
          filter: drop-shadow(0 0 2px rgba(232, 160, 107, 0.5));
          transform: scale(0.9);
        }
        50% {
          opacity: 1;
          filter: drop-shadow(0 0 8px rgba(232, 160, 107, 0.95));
          transform: scale(1.2);
        }
      }

      .vine-blossom {
        opacity: 0;
        transform-box: fill-box;
        transform-origin: center;
        animation:
          bloom 0.6s ease-out forwards,
          blossomSpin 9s linear infinite 3s;
      }
      @keyframes blossomSpin {
        0% {
          opacity: 0.7;
          transform: rotate(0deg) scale(0.95);
        }
        50% {
          opacity: 1;
          transform: rotate(180deg) scale(1.15);
        }
        100% {
          opacity: 0.7;
          transform: rotate(360deg) scale(0.95);
        }
      }

      .packet {
        fill: var(--green);
        filter: drop-shadow(0 0 5px rgba(124, 227, 154, 0.95));
      }
      .packet.ember {
        fill: var(--ember);
        filter: drop-shadow(0 0 5px rgba(232, 160, 107, 0.9));
      }
      .packet-trail {
        fill: none;
        stroke: var(--green);
        stroke-width: 2.5;
        stroke-linecap: round;
        opacity: 0.85;
        filter: drop-shadow(0 0 4px rgba(124, 227, 154, 0.7));
        stroke-dasharray: 22 1200;
        animation: travel 4.5s linear infinite 2.6s;
      }
      .packet-trail.slow {
        animation-duration: 6.5s;
      }
      .packet-trail.fast {
        animation-duration: 3.2s;
      }
      .packet-trail.ember {
        stroke: var(--ember);
        filter: drop-shadow(0 0 4px rgba(232, 160, 107, 0.7));
      }
      .packet-trail.d1 {
        animation-delay: 2.8s;
      }
      .packet-trail.d2 {
        animation-delay: 3.6s;
      }
      .packet-trail.d3 {
        animation-delay: 4.4s;
      }
      .packet-trail.d4 {
        animation-delay: 3.1s;
      }
      .packet-trail.d5 {
        animation-delay: 4s;
      }
      @keyframes travel {
        0% {
          stroke-dashoffset: 1222;
        }
        100% {
          stroke-dashoffset: 0;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .packet-trail,
        .vine-node,
        .vine-blossom {
          animation: none !important;
          opacity: 1 !important;
        }
      }

      @media (max-width: 760px) {
        .hero,
        .section,
        footer {
          padding-left: 1.25rem;
          padding-right: 1.25rem;
        }
        .section-head {
          flex-direction: column;
          align-items: flex-start;
          gap: 0.5rem;
        }
      }
    </style>
  </body>
</html>
