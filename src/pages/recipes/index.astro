---
import BaseHead from '../../components/BaseHead.astro'
import Header from '../../components/Header.astro'
import SucculentIcon from '../../components/SucculentIcon.astro'
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'

const recipes = (await getCollection('recipes')).sort((a, b) => a.data.title.localeCompare(b.data.title))

const toKey = (s: string) =>
  String(s)
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^a-z0-9\-]/g, '')

const mealTypes = ['Main', 'Side', 'Dessert']
const cuisines = ['American', 'Southwest / Tex-Mex', 'Italian', 'Asian-Inspired', 'Mediterranean', 'Middle Eastern', 'Indian', 'Caribbean', 'European (Non-Italian)', 'Global / Fusion']
const cookingMethods = ['Oven', 'Stovetop', 'Slow Cooker', 'Instant Pot', 'Grill', 'No-Cook']
const tags = ['Vegetarian', 'Gluten-Free', 'Dairy-Free', 'One Pan', 'Make Ahead']

const timeRangeStep = 5
const maxRecipeMinutes = recipes.reduce((max, recipe) => Math.max(max, recipe.data.activeTimeMinutes, recipe.data.totalTimeMinutes), 0)
const timeRangeMax = Math.max(timeRangeStep, Math.ceil(maxRecipeMinutes / timeRangeStep) * timeRangeStep)
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Recipes" />
    <style>
      .recipe-app {
        background: var(--paper);
        color: var(--cocoa);
      }

      /* ---------- Hero ---------- */
      .recipe-hero {
        position: relative;
        padding: 2.5rem 1.5rem 2rem;
        text-align: center;
        overflow: hidden;
      }
      :global(.recipe-hero-plant) {
        width: 36px;
        height: 36px;
        margin: 0 auto 0.75rem;
      }
      .recipe-h1 {
        font-family: var(--serif);
        font-weight: 700;
        font-size: clamp(2rem, 4vw, 2.75rem);
        letter-spacing: -0.02em;
        color: var(--forest);
        line-height: 1.05;
      }

      /* ---------- Shell / layout ---------- */
      .recipe-shell {
        max-width: 1280px;
        margin: 0 auto;
        padding: 0 1.5rem 5rem;
      }
      .recipe-grid-layout {
        display: grid;
        gap: 2rem;
      }
      @media (min-width: 1024px) {
        .recipe-grid-layout {
          grid-template-columns: 280px 1fr;
          align-items: start;
        }
      }

      /* ---------- Filters panel ---------- */
      .filters-panel {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .filters-panel-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
      }
      .filters-title {
        font-family: var(--serif);
        font-weight: 700;
        font-size: 1.15rem;
        color: var(--forest);
      }
      .filters-head-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .pill-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        border-radius: 999px;
        border: 1px solid var(--paper-line);
        background: var(--paper-card);
        padding: 0.4rem 0.85rem;
        font-family: var(--mono);
        font-size: 0.68rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--cocoa-soft);
        cursor: pointer;
        transition:
          border-color 0.15s ease,
          color 0.15s ease,
          background 0.15s ease;
      }
      .pill-btn:hover {
        border-color: var(--paper-line-hot);
        color: var(--forest);
        background: #fff;
      }

      .filter-group {
        border-radius: 16px;
        border: 1px solid var(--paper-line);
        background: var(--paper-card);
        padding: 0.9rem 1rem;
      }
      .filter-group summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        list-style: none;
        font-family: var(--mono);
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--forest);
        font-weight: 600;
      }
      .filter-group summary::-webkit-details-marker {
        display: none;
      }
      .filter-group summary svg {
        color: var(--cocoa-faint);
        transition: transform 0.2s ease;
      }
      .filter-group[open] summary svg {
        transform: rotate(180deg);
      }
      .filter-group-body {
        margin-top: 0.85rem;
      }

      .field {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        border-radius: 999px;
        border: 1px solid var(--paper-line);
        background: var(--paper);
        padding: 0.55rem 0.9rem;
      }
      .field:focus-within {
        border-color: var(--herb);
      }
      .field svg {
        color: var(--herb);
        flex-shrink: 0;
      }
      .field input {
        width: 100%;
        background: transparent;
        border: none;
        outline: none;
        font-size: 0.88rem;
        color: var(--cocoa);
        font-family: var(--sans);
      }
      .field input::placeholder {
        color: var(--cocoa-faint);
      }
      .field-hint {
        margin-top: 0.5rem;
        font-size: 0.72rem;
        color: var(--cocoa-faint);
      }
      .field + .field {
        margin-top: 0.6rem;
      }

      .chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }
      .filter-chip {
        cursor: pointer;
      }
      .chip-face {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid var(--paper-line);
        background: var(--paper);
        padding: 0.4rem 0.8rem;
        font-size: 0.82rem;
        color: var(--cocoa-soft);
        transition: all 0.15s ease;
        user-select: none;
      }
      .filter-chip:hover .chip-face {
        border-color: var(--paper-line-hot);
        color: var(--cocoa);
      }
      .filter-chip input:checked + .chip-face {
        background: var(--herb);
        border-color: var(--herb);
        color: #fff;
      }
      .filter-chip.accent-clay input:checked + .chip-face {
        background: var(--clay);
        border-color: var(--clay);
        color: #fff;
      }
      .filter-chip input:focus-visible + .chip-face {
        outline: 2px solid var(--herb);
        outline-offset: 2px;
      }

      .toggle-row {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        font-size: 0.85rem;
        color: var(--cocoa-soft);
        cursor: pointer;
      }
      .toggle-row input {
        accent-color: var(--herb);
        width: 16px;
        height: 16px;
      }

      .time-minutes-label {
        font-family: var(--mono);
        font-size: 0.68rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--cocoa-faint);
        margin-bottom: 0.5rem;
      }
      .time-track-wrap {
        position: relative;
        height: 2.5rem;
      }
      .time-track-bg {
        position: absolute;
        left: 0;
        right: 0;
        top: 50%;
        height: 4px;
        transform: translateY(-50%);
        border-radius: 999px;
        background: var(--paper-line);
      }
      #time-range-fill {
        position: absolute;
        top: 50%;
        height: 4px;
        transform: translateY(-50%);
        border-radius: 999px;
        background: var(--herb);
      }
      .time-range-labels {
        display: flex;
        justify-content: space-between;
        font-size: 0.75rem;
        color: var(--cocoa-faint);
      }

      .range-input {
        -webkit-appearance: none;
        appearance: none;
        background: transparent;
        pointer-events: auto;
        touch-action: none;
        cursor: grab;
      }
      .range-input:focus {
        outline: none;
      }
      .range-input::-webkit-slider-runnable-track {
        height: 2px;
      }
      .range-input::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 18px;
        width: 18px;
        border-radius: 999px;
        background: var(--herb);
        border: 2px solid #fff;
        box-shadow:
          0 0 0 1px var(--herb),
          0 2px 6px var(--paper-shadow);
        margin-top: -8px;
        cursor: pointer;
      }
      .range-input:active::-webkit-slider-thumb {
        cursor: grabbing;
      }
      .range-input::-moz-range-track {
        height: 2px;
        background: transparent;
      }
      .range-input::-moz-range-thumb {
        height: 18px;
        width: 18px;
        border-radius: 999px;
        background: var(--herb);
        border: 2px solid #fff;
        box-shadow:
          0 0 0 1px var(--herb),
          0 2px 6px var(--paper-shadow);
        cursor: pointer;
      }
      .range-input:active::-moz-range-thumb {
        cursor: grabbing;
      }
      .range-input::-ms-track {
        height: 2px;
        background: transparent;
        border-color: transparent;
        color: transparent;
      }

      #filters-panel {
        overscroll-behavior: contain;
      }
      #recipes-list {
        overflow-anchor: none;
      }

      /* ---------- Mobile drawer ---------- */
      .filters-scrim {
        display: none;
      }
      @media (max-width: 1023px) {
        .filters-scrim {
          position: fixed;
          inset: 0;
          z-index: 40;
          display: none;
          background: rgba(35, 26, 12, 0.45);
        }
        #filters-toggle:checked ~ .filters-scrim {
          display: block;
        }
        #filters-panel {
          position: fixed;
          inset-block: 0;
          left: 0;
          z-index: 50;
          width: 88vw;
          max-width: 22rem;
          transform: translateX(-100%);
          overflow-y: auto;
          background: var(--paper);
          padding: 1.25rem;
          box-shadow: 0 20px 60px var(--paper-shadow);
          transition: transform 0.3s ease-out;
        }
        #filters-toggle:checked ~ #filters-panel {
          transform: translateX(0);
        }
      }
      .mobile-close {
        display: none;
      }
      @media (max-width: 1023px) {
        .mobile-close {
          display: inline-flex;
        }
      }

      /* ---------- Results ---------- */
      .results-bar {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 1.5rem;
      }
      #summary {
        font-family: var(--mono);
        font-size: 0.78rem;
        letter-spacing: 0.04em;
        color: var(--cocoa-faint);
      }
      .mobile-filters-btn {
        display: inline-flex;
      }
      @media (min-width: 1024px) {
        .mobile-filters-btn {
          display: none;
        }
      }

      #no-results {
        display: none;
        align-items: center;
        gap: 0.9rem;
        border: 1px dashed var(--paper-line-hot);
        border-radius: 18px;
        background: var(--paper-card);
        padding: 1.25rem 1.5rem;
        color: var(--cocoa-soft);
      }
      #no-results:not(.hidden) {
        display: flex;
      }
      :global(.no-results-plant) {
        width: 2.25rem;
        height: 2.25rem;
        flex-shrink: 0;
        opacity: 0.75;
      }

      .recipe-grid {
        display: grid;
        gap: 1.75rem;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      }

      .recipe-card-link {
        display: block;
        text-decoration: none;
        color: inherit;
        border-radius: 20px;
        background: var(--paper-card);
        border: 1px solid var(--paper-line);
        overflow: hidden;
        transition:
          transform 0.25s ease,
          border-color 0.25s ease,
          box-shadow 0.25s ease;
      }
      .recipe-card-link:hover {
        transform: translateY(-4px);
        border-color: var(--paper-line-hot);
        box-shadow: 0 20px 40px -20px var(--paper-shadow);
      }
      .recipe-card-photo-wrap {
        aspect-ratio: 4 / 3;
        overflow: hidden;
        background: var(--paper-line);
      }
      .recipe-card-photo-wrap :global(img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
      }
      .recipe-card-link:hover .recipe-card-photo-wrap :global(img) {
        transform: scale(1.05);
      }
      .recipe-card-body {
        padding: 1.1rem 1.15rem 1.25rem;
      }
      .recipe-card-title {
        font-family: var(--serif);
        font-size: 1.3rem;
        font-weight: 700;
        line-height: 1.2;
        color: var(--forest);
        transition: color 0.15s ease;
      }
      .recipe-card-link:hover .recipe-card-title {
        color: var(--clay);
      }
      .recipe-card-meta {
        margin-top: 0.5rem;
        font-size: 0.82rem;
        color: var(--cocoa-faint);
      }
      .recipe-card-meta strong {
        color: var(--cocoa-soft);
        font-weight: 600;
      }
    </style>
  </head>

  <body class="recipe-app">
    <Header title="Recipes" />

    <div class="recipe-hero">
      <SucculentIcon class="recipe-hero-plant" />
      <h1 class="recipe-h1">Recipes</h1>
    </div>

    <main class="recipe-shell">
      <div class="recipe-grid-layout">
        <input
          id="filters-toggle"
          type="checkbox"
          class="sr-only"
        />
        <label
          for="filters-toggle"
          class="filters-scrim"
          aria-hidden="true"
        ></label>

        <aside
          id="filters-panel"
          class="filters-panel"
        >
          <div class="filters-panel-head">
            <h2 class="filters-title">Filters</h2>
            <div class="filters-head-actions">
              <label
                for="filters-toggle"
                class="pill-btn mobile-close"
                role="button"
              >
                Close
              </label>
              <button
                id="clear"
                type="button"
                class="pill-btn"
              >
                Clear
              </button>
            </div>
          </div>

          <details
            open
            class="filter-group"
          >
            <summary>
              Search
              <svg
                width="16"
                height="16"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M5 7l5 5 5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </summary>
            <div class="filter-group-body">
              <div class="field">
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M21 21l-4.2-4.2m1.7-5.1A7.5 7.5 0 1 1 4 6.5 7.5 7.5 0 0 1 18.5 11.7z"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  ></path>
                </svg>
                <label
                  for="q"
                  class="sr-only"
                  >Search</label
                >
                <input
                  id="q"
                  type="search"
                  placeholder="Title..."
                />
              </div>
              <div class="field">
                <svg
                  width="15"
                  height="15"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M4 7h16M4 12h16M4 17h16"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                  ></path>
                </svg>
                <label
                  for="ingredients"
                  class="sr-only"
                  >Ingredients</label
                >
                <input
                  id="ingredients"
                  type="text"
                  placeholder="Ingredients…"
                />
              </div>
              <p class="field-hint">Separate ingredients with commas.</p>
            </div>
          </details>

          <details
            open
            class="filter-group"
          >
            <summary>
              Meal Type
              <svg
                width="16"
                height="16"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M5 7l5 5 5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </summary>
            <div class="filter-group-body chip-row">
              {
                mealTypes.map((course) => (
                  <label class="filter-chip">
                    <input
                      type="checkbox"
                      class="sr-only"
                      data-filter="course"
                      value={toKey(course)}
                    />
                    <span class="chip-face">{course}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <details
            open
            class="filter-group"
          >
            <summary>
              Cuisine
              <svg
                width="16"
                height="16"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M5 7l5 5 5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </summary>
            <div class="filter-group-body chip-row">
              {
                cuisines.map((cuisine) => (
                  <label class="filter-chip">
                    <input
                      type="checkbox"
                      class="sr-only"
                      data-filter="cuisine"
                      value={toKey(cuisine)}
                    />
                    <span class="chip-face">{cuisine}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <details
            open
            class="filter-group"
          >
            <summary>
              Cooking Method
              <svg
                width="16"
                height="16"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M5 7l5 5 5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </summary>
            <div class="filter-group-body chip-row">
              {
                cookingMethods.map((method) => (
                  <label class="filter-chip accent-clay">
                    <input
                      type="checkbox"
                      class="sr-only"
                      data-filter="method"
                      value={toKey(method)}
                    />
                    <span class="chip-face">{method}</span>
                  </label>
                ))
              }
            </div>
          </details>

          <details
            open
            class="filter-group"
          >
            <summary>
              Time
              <svg
                width="16"
                height="16"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M5 7l5 5 5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </summary>
            <div class="filter-group-body">
              <label class="toggle-row">
                <input
                  id="timeIncludeInactive"
                  type="checkbox"
                />
                Include prep/marinate time
              </label>

              <div style="margin-top: 0.9rem;">
                <p class="time-minutes-label">Minutes</p>
                <div class="time-track-wrap">
                  <div class="time-track-bg"></div>
                  <div id="time-range-fill"></div>
                  <input
                    id="maxTime"
                    type="range"
                    min="0"
                    max={String(timeRangeMax)}
                    step={String(timeRangeStep)}
                    value={String(timeRangeMax)}
                    class="range-input absolute left-0 top-1/2 z-10 h-8 w-full -translate-y-1/2"
                  />
                </div>
                <div class="time-range-labels">
                  <span>0 min</span>
                  <span id="maxTimeLabel">{timeRangeMax} min</span>
                </div>
              </div>
            </div>
          </details>

          <details
            open
            class="filter-group"
          >
            <summary>
              Tags
              <svg
                width="16"
                height="16"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path
                  d="M5 7l5 5 5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                ></path>
              </svg>
            </summary>
            <div class="filter-group-body">
              <label
                class="toggle-row"
                style="margin-bottom: 0.75rem;"
              >
                <input
                  id="tagsMatchAll"
                  type="checkbox"
                />
                Match all selected tags
              </label>
              <div class="chip-row">
                {
                  tags.map((tag) => (
                    <label class="filter-chip">
                      <input
                        type="checkbox"
                        class="sr-only"
                        data-filter="tag"
                        value={toKey(tag)}
                      />
                      <span class="chip-face">{tag}</span>
                    </label>
                  ))
                }
              </div>
            </div>
          </details>
        </aside>

        <section id="recipes-list">
          <div class="results-bar">
            <p id="summary"></p>
            <label
              for="filters-toggle"
              class="pill-btn mobile-filters-btn"
              role="button"
            >
              Filters
            </label>
          </div>

          <p
            id="no-results"
            class="hidden"
          >
            <SucculentIcon class="no-results-plant" />
            No recipes match these filters — this patch came up dry.
          </p>

          <ul class="recipe-grid">
            {
              recipes.map((recipe) => (
                <li
                  class="recipe-card"
                  data-course={recipe.data.course.map(toKey).join(',')}
                  data-cuisine={recipe.data.cuisine.map(toKey).join(',')}
                  data-method={recipe.data.cookingMethod.map(toKey).join(',')}
                  data-tags={recipe.data.tags.map(toKey).join(',')}
                  data-active-minutes={String(recipe.data.activeTimeMinutes)}
                  data-total-minutes={String(recipe.data.totalTimeMinutes)}
                  data-search={recipe.data.title.toLowerCase()}
                  data-ingredients-list={JSON.stringify(recipe.data.ingredients.filter((i) => 'name' in i).map((i) => i.name))}
                  data-ingredients={recipe.data.ingredients
                    .filter((i) => 'name' in i)
                    .map((i) => i.name)
                    .join(' ')
                    .toLowerCase()}
                >
                  <a
                    href={`/recipes/${recipe.id}/`}
                    class="recipe-card-link"
                  >
                    <div class="recipe-card-photo-wrap">
                      {recipe.data.heroImage && (
                        <Image
                          src={recipe.data.heroImage}
                          alt={recipe.data.title}
                          widths={[360, 720]}
                          sizes="(max-width: 720px) 100vw, 360px"
                          loading="lazy"
                          decoding="async"
                        />
                      )}
                    </div>
                    <div class="recipe-card-body">
                      <h2 class="recipe-card-title">{recipe.data.title}</h2>
                      <p class="recipe-card-meta">
                        <strong>Prep</strong> {recipe.data.prepTime} <strong>· Cook</strong> {recipe.data.cookTime}
                        {recipe.data.inactiveTime && <span> · +{recipe.data.inactiveTime}</span>}
                      </p>
                    </div>
                  </a>
                </li>
              ))
            }
          </ul>
        </section>
      </div>
    </main>

    <script>
      // @ts-nocheck
      ;(function () {
        const cards = Array.from(document.querySelectorAll('.recipe-card'))
        const q = document.getElementById('q')
        const ingredients = document.getElementById('ingredients')
        const tagsMatchAll = document.getElementById('tagsMatchAll')
        const timeIncludeInactive = document.getElementById('timeIncludeInactive')
        const maxTime = document.getElementById('maxTime')
        const maxTimeLabel = document.getElementById('maxTimeLabel')
        const timeFill = document.getElementById('time-range-fill')
        const clear = document.getElementById('clear')
        const summary = document.getElementById('summary')
        const noResults = document.getElementById('no-results')

        if (!q || !ingredients || !tagsMatchAll || !timeIncludeInactive || !maxTime || !maxTimeLabel || !timeFill || !clear || !summary || !noResults) {
          return
        }

        const courseInputs = Array.from(document.querySelectorAll('input[data-filter="course"]'))
        const cuisineInputs = Array.from(document.querySelectorAll('input[data-filter="cuisine"]'))
        const methodInputs = Array.from(document.querySelectorAll('input[data-filter="method"]'))
        const tagInputs = Array.from(document.querySelectorAll('input[data-filter="tag"]'))

        const timeRangeMax = Number((maxTime && maxTime.max) || '0') || 180

        function normalizeText(text) {
          return String(text || '')
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, ' ')
            .trim()
        }

        function parseList(s) {
          return String(s || '')
            .split(',')
            .map((x) => x.trim())
            .filter(Boolean)
        }

        function parseJsonList(value) {
          if (!value) return []
          try {
            const parsed = JSON.parse(value)
            if (Array.isArray(parsed)) return parsed.map((item) => String(item))
          } catch (err) {
            return []
          }
          return []
        }

        function getSelected(inputs) {
          return new Set(inputs.filter((input) => input.checked).map((input) => input.value))
        }

        function hasAny(haystack, needles) {
          if (!needles.size) return true
          for (const v of haystack) if (needles.has(v)) return true
          return false
        }

        function hasAll(haystack, needles) {
          if (!needles.size) return true
          for (const v of needles) if (!haystack.includes(v)) return false
          return true
        }

        function hasIngredientMatch(ingredientsList, term) {
          if (!term) return true
          for (const ingredient of ingredientsList) {
            if (ingredient.includes(term)) return true
          }
          return false
        }

        const cardData = cards.map((card) => {
          const ingredientsList = parseJsonList(card.dataset.ingredientsList)
          const normalizedIngredients = ingredientsList.length ? ingredientsList.map((item) => normalizeText(item)).filter(Boolean) : [normalizeText(card.dataset.ingredients || '')].filter(Boolean)

          return {
            card,
            courseKeys: parseList(card.dataset.course),
            cuisineKeys: parseList(card.dataset.cuisine),
            methodKeys: parseList(card.dataset.method),
            tagKeys: parseList(card.dataset.tags),
            searchText: normalizeText(card.dataset.search || ''),
            ingredientsText: normalizedIngredients,
            activeMinutes: Number(card.dataset.activeMinutes || '0'),
            totalMinutes: Number(card.dataset.totalMinutes || '0'),
          }
        })

        function syncTimeRange() {
          const maxValue = Number(maxTime.value || String(timeRangeMax))
          maxTimeLabel.textContent = `${maxValue} min`

          const right = 100 - (maxValue / timeRangeMax) * 100
          timeFill.style.left = '0%'
          timeFill.style.right = `${right}%`
        }

        function applyFilters() {
          const selectedCourses = getSelected(courseInputs)
          const selectedCuisines = getSelected(cuisineInputs)
          const selectedMethods = getSelected(methodInputs)
          const selectedTags = getSelected(tagInputs)
          const tagsMatchAllChecked = !!tagsMatchAll.checked
          const timeBasis = timeIncludeInactive.checked ? 'total' : 'active'

          const qTokens = normalizeText(q.value).split(/\s+/).filter(Boolean)

          const ingredientTerms = ingredients.value
            .split(/[,\n]+/)
            .map((term) => normalizeText(term))
            .filter(Boolean)

          const minValue = 0
          const maxValue = Number(maxTime.value || String(timeRangeMax))

          let shown = 0

          cardData.forEach((cardItem) => {
            const minutes = timeBasis === 'total' ? cardItem.totalMinutes : cardItem.activeMinutes

            const passCourse = hasAny(cardItem.courseKeys, selectedCourses)
            const passCuisine = hasAny(cardItem.cuisineKeys, selectedCuisines)
            const passMethod = hasAny(cardItem.methodKeys, selectedMethods)

            const passTags = selectedTags.size ? (tagsMatchAllChecked ? hasAll(cardItem.tagKeys, selectedTags) : hasAny(cardItem.tagKeys, selectedTags)) : true

            const passTime = minutes >= minValue && minutes <= maxValue

            const passQuery = qTokens.length ? qTokens.every((t) => cardItem.searchText.includes(t)) : true

            const passIngredients = ingredientTerms.length ? ingredientTerms.every((term) => hasIngredientMatch(cardItem.ingredientsText, term)) : true

            const show = passCourse && passCuisine && passMethod && passTags && passTime && passQuery && passIngredients
            cardItem.card.classList.toggle('hidden', !show)
            if (show) shown++
          })

          summary.textContent = `${shown} / ${cards.length} recipes`
          noResults.classList.toggle('hidden', shown !== 0)
        }

        courseInputs.forEach((input) => input.addEventListener('change', applyFilters))
        cuisineInputs.forEach((input) => input.addEventListener('change', applyFilters))
        methodInputs.forEach((input) => input.addEventListener('change', applyFilters))
        tagInputs.forEach((input) => input.addEventListener('change', applyFilters))

        q.addEventListener('input', applyFilters)
        ingredients.addEventListener('input', applyFilters)

        tagsMatchAll.addEventListener('change', () => {
          applyFilters()
        })

        timeIncludeInactive.addEventListener('change', () => {
          applyFilters()
        })

        maxTime.addEventListener('input', syncTimeRange)
        maxTime.addEventListener('change', applyFilters)

        clear.addEventListener('click', () => {
          q.value = ''
          ingredients.value = ''
          tagsMatchAll.checked = false
          timeIncludeInactive.checked = false
          maxTime.value = String(timeRangeMax)

          courseInputs.forEach((input) => (input.checked = false))
          cuisineInputs.forEach((input) => (input.checked = false))
          methodInputs.forEach((input) => (input.checked = false))
          tagInputs.forEach((input) => (input.checked = false))

          syncTimeRange()
          applyFilters()
        })

        syncTimeRange()
        applyFilters()
      })()
    </script>
  </body>
</html>
